        "id": "string",
        "name": "string",
        "file_id": "string",
        "next_id": "string|null",
        "prev_id": "string|null",
        "size": "number",
        "type": {
          "enum": [
            "definition",
            "theorem",
            "proposition"
          ]
        },
        "content": {
          "content": "string",
          "proof": "string|null"
        },
        "created_at": "number|string",
        "updated_at": "number|string"
      }
    },
    "operations": {
